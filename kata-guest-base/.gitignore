# scripts/fetch.sh caches the ~1.4 GB kata-static tarball here between
# runs so a re-run doesn't re-download it. The sha256 pin in fetch.sh
# is the trust anchor; the cache is just a network-bandwidth saver.
.fetch-cache/

# confos build artifacts (mkosi sandbox is invoked from scripts/build.sh
# but writes into /workspace/confidential-os-builder/output/...; nothing should normally
# land here, but be defensive).
output/

# Debug-variant build output (scripts/build.sh Step 5/5 — same artifact
# layout as output/, guest policy allows host log/exec RPCs).
output-debug/

# Local-only marker dropped by fetch.sh — useful for "what version was
# this image baked against" but not source-controlled.
extra/usr/local/share/c8s/.kata-guest-base-baked
extra/usr/local/share/c8s/upstream-kata/

# In-guest binaries staged into the overlay by scripts/fetch.sh +
# build.sh (ratls-mesh, policy-monitor, attestation-service, kata-agent,
# CoCo guest-components). Built artifacts, not source-controlled; the
# dir is created at build time. fetch.sh documents the expected set.
extra/usr/local/bin/

# Generated by scripts/fetch.sh from bootstrap-allowlist.json.template by
# substituting the resolved cds/get-cert image digests at IMAGE_TAG. The
# .template is the source of truth; this materialised copy is a build
# artifact (its digests go stale) and is regenerated on every build.
extra/etc/c8s/bootstrap-allowlist.json

# In-guest registry auth for guest-pull: a docker auth.json baked into the
# dm-verity rootfs. GENERATED at build time by scripts/fetch.sh — empty in
# stock builds; a pre-staged file (private-mirror creds) may hold a real
# credential, so it is NEVER source-controlled. See docs/pitfalls.md
# "ghcr-auth.json" + README.md "Guest-pull registry auth".
extra/etc/c8s/ghcr-auth.json
