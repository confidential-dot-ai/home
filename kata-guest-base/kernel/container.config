# Kernel config fragment for the kata-guest-base image.
#
# This fragment is applied AFTER confos's `required.config` + `hardening.config`.
# Its job is to widen the hardened microVM kernel just enough that the kata
# guest agent can run inside a confidential VM produced by either kata-qemu-snp
# (AMD SEV-SNP) or kata-qemu-tdx (Intel TDX): virtio transport, the vsock
# channel between guest and host, the in-guest 9p mount kata uses for
# cloud-init NoCloud, the guest-side networking devices the kata-agent
# assumes are present, and the guest-side drivers for BOTH x86 TEEs so a
# single artifact runs on either.
#
# confos's required.config already enables the SEV-SNP guest options
# (CONFIG_AMD_MEM_ENCRYPT, CONFIG_SEV_GUEST, CONFIG_VIRT_DRIVERS). TDX guest
# support (CONFIG_INTEL_TDX_GUEST, CONFIG_TDX_GUEST_DRIVER, CONFIG_X86_X2APIC)
# lives in confos's OPTIONAL `confidential.config` fragment — and `confos kernel
# --kernel-config-fragment` only accepts one path — so those knobs are
# re-declared HERE for the TDX arm. Do not duplicate the SNP options in this
# file: duplicating a config line in a fragment can silently flip its source
# attribution under merge_config.sh and surface as snapshot drift on the next
# build.
#
# Bumping this list is a measurement change. The resolved-config snapshot
# (kernel/config-x86_64.snapshot, next to this file) is the merged result
# of confos's baseline + this fragment. confos generates it during the
# kernel build and scripts/build.sh copies it here, committed, so the
# effect of an edit is reviewable in `git diff` — review the snapshot diff
# alongside any change here, and commit the two together. See README.md
# "Build" and /workspace/confidential-os-builder/README.md "Snapshots".

# --- Intel TDX guest support (twin of confos required.config's SEV_GUEST) ---
#
# Enables /dev/tdx_guest and the kernel side of TDREPORT / GetQuote — the
# ioctls the in-guest attestation-service uses on a kata-qemu-tdx pod. On a
# kata-qemu-snp host these are inert (X86_FEATURE_TDX_GUEST is runtime-probed,
# so an SNP guest never enters the TDX code paths). X2APIC is a hard TDX
# dependency (Kconfig refuses INTEL_TDX_GUEST without it) and is the standard
# QEMU/KVM interrupt controller mode; enabling it on SNP is a no-op.
# ACPI_TABLE_UPGRADE mirrors confos's confidential.config — kata's dm-verity
# rootfs is measured via kernel_verity_params folded into the launch digest,
# so ACPI overrides in the rootfs are attested (same threat model as confos).
CONFIG_X86_X2APIC=y
CONFIG_INTEL_TDX_GUEST=y
CONFIG_TDX_GUEST_DRIVER=y
CONFIG_ACPI_TABLE_UPGRADE=y

# --- Virtio transports (kata-qemu, kata-qemu-snp, kata-qemu-tdx all expose virtio) ----

CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BALLOON=y

# Virtio block: the kata-agent rootfs is delivered as a virtio-blk device.
CONFIG_VIRTIO_BLK=y
CONFIG_BLK_DEV=y

# --- dm-verity early boot (kata measured-rootfs root device) --------------
#
# kata-qemu-snp and kata-qemu-tdx both boot our rootfs as a dm-verity device:
# they put `dm-mod.create="dm-verity,..." root=/dev/dm-0` on the kernel
# cmdline and expect the kernel to assemble /dev/dm-0 from that BEFORE
# mounting root.
# That early-creation path is dm-init, gated on CONFIG_DM_INIT — which is
# SEPARATE from CONFIG_BLK_DEV_DM / CONFIG_DM_VERITY (both already =y in
# confos's required.config, so not re-declared here). Without DM_INIT the
# cmdline param is silently ignored, /dev/dm-0 never appears, and the guest
# panics: `VFS: Cannot open root device "/dev/dm-0" ... Unable to mount
# root fs`.
CONFIG_DM_INIT=y

# Virtio net: the kata-agent attaches the pod network interface as
# virtio-net. Without this the pod has no network and ratls-mesh's
# in-guest iptables redirects have nothing to redirect.
CONFIG_VIRTIO_NET=y
CONFIG_NET=y
CONFIG_INET=y

# Virtio console: kata-agent's logs and (for the --console build flag
# during development) the operator-side serial.
CONFIG_VIRTIO_CONSOLE=y

# --- vsock — the kata-agent control channel ------------------------------
#
# kata-runtime talks to kata-agent over vsock (CID-based, no IP). The
# guest needs the vhost-vsock driver enabled to register; without this
# kata-agent never reaches the runtime and the pod times out at
# CreateContainer.

CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# --- 9p — kata's NoCloud cloud-init datasource ---------------------------
#
# kata-runtime mounts the per-pod cloud-init user-data into the guest via
# 9p (the upstream-blessed mechanism — see kata-containers/runtime
# documentation on "cloud-init in kata"). cloud-init's NoCloud datasource
# picks it up from /var/lib/cloud/seed/nocloud at first boot.

CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y
CONFIG_9P_FS_SECURITY=y

# --- virtiofs — kata's alternative shared-fs path ------------------------
#
# Some kata variants pass per-pod metadata via virtiofs rather than 9p
# (depending on the hypervisor; kata-qemu-snp prefers virtiofs for the
# rootfs overlay). Compiling both in costs ~40KB and removes one source
# of "works on qemu, breaks on clh" footguns.

CONFIG_VIRTIO_FS=y
CONFIG_FUSE_FS=y

# --- Guest workload networking (iptables / nftables NAT for ratls) -------
#
# ratls-mesh in-guest mode applies iptables REDIRECT rules on the pod
# interface so workload-originated traffic hits its outbound proxy on
# 15001 and inbound traffic from peers hits 15006. The guest kernel
# therefore needs the same netfilter primitives ratls-mesh uses on the
# host today (see /workspace/base-images/rke2/kernel/container.config
# for the host-side superset).

CONFIG_NETFILTER=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_REDIRECT=y
CONFIG_NF_NAT_MASQUERADE=y

# Legacy iptables (xt_REDIRECT is what `iptables -t nat -j REDIRECT` uses).
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_NAT=y

# nf_tables backend. The ubuntu-noble rootfs defaults the `iptables`
# alternative to iptables-nft, and ratls-mesh's in-guest setup programs NAT
# REDIRECT chains for BOTH families (in_guest_linux.go iterates IPv4+IPv6),
# treating a failure on either as fatal. The base kernel shipped only legacy
# IPv4 NAT, so iptables-nft failed ("Could not fetch rule set generation id")
# and ip6tables had no nat table — ratls-mesh died and c8s-ready.target was
# never reached. Enabling nf_tables (+ the nat/redir expressions and the
# xtables compat shim) makes the stock iptables-nft userspace work unmodified
# for v4 and v6. Chosen over legacy IP6_NF_NAT because that pulls in the broad
# CONFIG_NETFILTER_ADVANCED (larger attack surface); the nft symbols below do
# not depend on it. Deps already satisfied above: NF_CONNTRACK, NF_NAT,
# NF_NAT_REDIRECT, NETFILTER_NETLINK, plus IPV6=y in the snapshot.
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_COMPAT=y

# ratls-mesh's in-guest chains also use the `owner` match (RETURN on its own
# proxy UID 1337 to avoid a redirect loop) and `set` match + ipset (peer-CIDR
# tracking, hash:ip). Both xt modules sit behind NETFILTER_ADVANCED, so it must
# be enabled. The fragment force-sets every netfilter symbol ratls needs above,
# so exposing the advanced menu does not drop them (verified in the snapshot).
# Without these, ratls-mesh dies at iptables setup ("owner: missing kernel
# module" / RULE_APPEND failed) and c8s-ready.target is never reached.
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_XT_MATCH_OWNER=y
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_NETFILTER_XT_SET=y

# ipset — ratls-mesh uses ipsets to track the live peer CIDR list.
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_IP=y

# --- TCP diagnostics — operator-facing inside the guest ------------------

CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y

# --- cgroups (kata-agent runs the workload container inside the VM) -------
#
# kata-agent uses libcontainer; the guest kernel needs the cgroup
# controllers libcontainer expects (memory, pids, cpu). Without these
# cgroup writes inside the guest fail and the workload container won't
# start. Kept minimal — features kata's guest doesn't use (perf event,
# rdma, hugetlb) stay off.

CONFIG_CGROUPS=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_CGROUP_FREEZER=y

# --- /proc/sys/net/* sysctls used by ratls-mesh's iptables setup ---------

CONFIG_SYSCTL=y
CONFIG_PROC_SYSCTL=y

# --- Force-off: legacy kexec ---------------------------------------------
#
# confos's hardening baseline leaves CONFIG_KEXEC=y (KEXEC_FILE and
# KEXEC_JUMP are already off). The legacy kexec syscall lets in-guest
# root boot an unmeasured kernel, bypassing measured boot — the launch
# measurement covers the vmlinuz we shipped, but a kexec'd kernel is not
# in the TCB. Force it off here; merge_config.sh honors the `is not set`
# form and turns the baseline's =y back off.
# CONFIG_KEXEC is not set
