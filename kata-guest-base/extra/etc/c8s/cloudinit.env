# INTERIM broker-bootstrap config for the in-guest c8s mesh.
#
# This is the static fallback the c8s-cloudinit-env.service materialises into
# /run/c8s/ratls-mesh.env when there is no per-pod cloud-init NoCloud
# datasource. It exists so the chart-managed CDS broker — and, today, every
# kata-qemu-snp pod — can reach c8s-ready.target without the unbuilt per-pod
# cloud-init injection (the mutator-side extension; see
# docs/kata-guest-base.md).
#
# TRADE-OFFS (deliberate, see docs/decisions/):
#   - These are the DEFAULT release/namespace service URLs (release "c8s",
#     namespace "c8s-system"). A non-default install must override them via
#     the real per-pod injection once it lands.
#   - C8S_WORKLOAD_ID is a fixed broker identity shared by every pod that uses
#     this baked file; per-pod identity also needs the real injection.
#   - Values are non-secret (service URLs + a workload id), so baking them into
#     the dm-verity-measured rootfs is acceptable (the host can already see
#     cloud-init user-data anyway — secrets are minted in-guest via RA-TLS).
# C8S_CDS_MEASUREMENTS is deliberately absent — it cannot be baked (the value
# would change the launch measurement it pins) and must not be host-injected.
# See docs/GAPS.md ("in-guest CDS allowlist refresh").
C8S_WORKLOAD_ID=c8s-broker
C8S_CDS_URL=https://c8s-cds.c8s-system.svc:8443
C8S_ATTESTATION_SERVICE_URL=http://127.0.0.1:8400
C8S_PLATFORM=auto
C8S_LOG_LEVEL=info
# tcp:8443 exempts the public front doors (tls-lb nginx, CDS — both terminate
# attestation-anchored TLS themselves) from the inbound mTLS redirect. Because
# this env is a single baked default, it applies to EVERY guest: a workload
# listening on 8443 inside a kata pod is reachable without mesh mTLS. See
# docs/pitfalls.md — "kata guests: inbound TCP port 8443 bypasses the mesh".
C8S_MESH_INBOUND_PASSTHROUGH=tcp:8443
